{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trait",
  "type": "object",
  "description": "Combination of Item attribute key with list of values",
  "required": [
    "key",
    "values"
  ],
  "properties": {
    "key": {
      "$ref": "#/components/schemas/TraitEntry"
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/components/schemas/TraitEntry"
      }
    }
  }
}