{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventTimeMark",
  "type": "object",
  "required": [
    "name",
    "date"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Describes 'place' where event has been handled/received"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    }
  }
}