{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Orders",
  "type": "object",
  "properties": {
    "continuation": {
      "type": "string",
      "description": "Continuation token to paginate orders search result"
    },
    "orders": {
      "type": "array",
      "description": "List of found orders",
      "default": [],
      "items": {
        "$ref": "#/components/schemas/Order"
      }
    }
  },
  "required": [
    "orders"
  ]
}