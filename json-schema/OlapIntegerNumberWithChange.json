{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OlapIntegerNumberWithChange",
  "required": [
    "value"
  ],
  "type": "object",
  "properties": {
    "value": {
      "type": "integer",
      "description": "Value of integer number",
      "format": "int64"
    },
    "changePercent": {
      "type": "number",
      "description": "Change in percent. Calculated as <current period value> / <previous period value> - 1",
      "format": "bigdecimal"
    }
  }
}