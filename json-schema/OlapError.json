{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OlapError",
  "required": [
    "code",
    "message"
  ],
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "Code",
      "enum": [
        "INVALID_INPUT",
        "NOT_FOUND",
        "UNKNOWN"
      ]
    },
    "message": {
      "type": "string",
      "description": "Message"
    }
  }
}