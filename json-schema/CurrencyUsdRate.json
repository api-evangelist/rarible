{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CurrencyUsdRate",
  "type": "object",
  "required": [
    "symbol",
    "rate",
    "date"
  ],
  "properties": {
    "currencyId": {
      "deprecated": true,
      "type": "string",
      "description": "Currency Id",
      "example": "usdc"
    },
    "symbol": {
      "type": "string",
      "description": "Currency Symbol",
      "example": "usdc"
    },
    "abbreviation": {
      "type": "string"
    },
    "rate": {
      "$ref": "#/components/schemas/BigDecimal"
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time of currency USD rate"
    }
  }
}