{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Currency",
  "type": "object",
  "properties": {
    "currencyId": {
      "$ref": "#/components/schemas/CurrencyId"
    },
    "symbol": {
      "type": "string"
    },
    "abbreviation": {
      "type": "string"
    },
    "alias": {
      "type": "string",
      "description": "Alias to real coin, 'usd' means 1:1 to USD"
    },
    "rate": {
      "$ref": "#/components/schemas/BigDecimal"
    },
    "decimals": {
      "type": "integer",
      "format": "int32",
      "description": "Number of decimals"
    }
  },
  "required": [
    "currencyId",
    "symbol",
    "decimals"
  ]
}