{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraitProperty",
  "type": "object",
  "description": "Item trait property",
  "required": [
    "key",
    "value"
  ],
  "properties": {
    "key": {
      "type": "string",
      "example": "Hat"
    },
    "value": {
      "type": "string",
      "example": "Halo"
    }
  }
}