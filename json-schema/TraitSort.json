{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TraitSort",
  "type": "object",
  "description": "Used when the search sort is set as TRAIT",
  "required": [
    "key"
  ],
  "properties": {
    "key": {
      "type": "string",
      "description": "Trait key",
      "example": "hat"
    },
    "order": {
      "$ref": "#/components/schemas/SortOrder"
    },
    "type": {
      "$ref": "#/components/schemas/SortType"
    }
  }
}